# ====================================================================
# Конфигурация P2P-бота. Скопируй в .env и заполни реальными значениями:
#   cp .env.example .env
# ВНИМАНИЕ: формат systemd EnvironmentFile — БЕЗ кавычек и без пробелов
# вокруг знака =. Просто KEY=value.
# ====================================================================

# Токен бота от @BotFather (ОБЯЗАТЕЛЬНО)
BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID администраторов через запятую (ОБЯЗАТЕЛЬНО хотя бы один)
ADMIN_IDS=111111111,222222222

# ID мерчантов через запятую (можно оставить пустым)
MERCHANT_IDS=333333333

# Путь к файлу состояния. Абсолютный путь надёжнее для systemd.
STATE_FILE=/opt/p2p-bot/state.json

# Стандартный TTL заявки в минутах (по умолчанию 15)
DEFAULT_TTL_MIN=15

# Порт healthcheck-сервера (слушает только localhost)
PORT=5000

# Интерфейс HTTP-сервера. 127.0.0.1 — наружу не торчит (рекомендуется).
# Меняй на 0.0.0.0 только если точно знаешь зачем и закрыл порт фаерволом.
HTTP_HOST=127.0.0.1
